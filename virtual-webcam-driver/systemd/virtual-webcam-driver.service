[Unit]
Description=Virtual Webcam Driver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/virtual-webcam-driver/service.env
WorkingDirectory=%h
ExecStart=/bin/bash -lc 'cd "$APP_ROOT" && exec ./bin/start.sh'
Restart=on-failure
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
